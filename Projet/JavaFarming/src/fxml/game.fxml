<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="850.0" style="-fx-background-color: #3e2723;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.gameController">
    <children>
        <HBox alignment="CENTER" layoutX="20.0" layoutY="20.0" prefHeight="70.0" prefWidth="810.0" spacing="30.0" style="-fx-background-color: #795548; -fx-background-radius: 10; -fx-border-color: #5d4037; -fx-border-width: 4;">
            <children>
                <ComboBox fx:id="comboSeedSelected" prefHeight="45.0" prefWidth="200.0" promptText="Choisir une Graine" style="-fx-background-color: #ffffff;            -fx-border-color: #5d4037;            -fx-border-width: 3;            -fx-background-radius: 0;            -fx-border-radius: 0;            -fx-font-size: 14px;            -fx-text-fill: #3e2723;" />
                <Button mnemonicParsing="false" onAction="#openShop" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #ffca28;                -fx-text-fill: #3e2723;                -fx-font-family: 'System';                -fx-font-weight: bold;                -fx-font-size: 14px;                -fx-border-color: #ffa000;                -fx-border-width: 2;                -fx-background-radius: 0;                -fx-border-radius: 0;" text="BOUTIQUE" />
                <Label fx:id="lblUserMoney" prefHeight="36.0" prefWidth="162.0" style="-fx-text-fill: #c8e6c9;" text="Argent: 1500$" textAlignment="CENTER">
                    <font>
                        <Font name="Consolas Bold" size="20.0" />
                    </font>
                </Label>
            <ComboBox fx:id="comboAnimalSelected" prefHeight="45.0" prefWidth="200.0" promptText="Choisir un Animal" style="-fx-background-color: #ffffff;            -fx-border-color: #5d4037;            -fx-border-width: 3;            -fx-background-radius: 0;            -fx-border-radius: 0;            -fx-font-size: 14px;            -fx-text-fill: #3e2723;" />
            </children>
        </HBox>

        <HBox alignment="CENTER" layoutX="25.0" layoutY="110.0" prefHeight="340.0" prefWidth="800.0" spacing="50.0">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="MA FERME" textFill="WHITE" />
                        <GridPane fx:id="farmGrid" style="-fx-background-color: #8BC34A; -fx-padding: 5; -fx-border-color: #558B2F; -fx-border-width: 5; -fx-background-radius: 5;" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="ENCLOS ANIMAUX" textFill="WHITE" />
                        <GridPane fx:id="animalGrid" style="-fx-background-color: #A1887F; -fx-padding: 5; -fx-border-color: #6D4C41; -fx-border-width: 5; -fx-background-radius: 5;" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <HBox layoutX="25.0" layoutY="532.0" prefHeight="150.0" prefWidth="800.0" spacing="20.0">
            <children>
                <VBox prefWidth="380.0" spacing="5.0" style="-fx-background-color: #d7ccc8; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #a1887f;">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #5d4037;" text="STOCK GRAINES" />
                        <Label fx:id="lblUserWheatSeedStock" text="0 Graine de Blé" />
                        <Label fx:id="lblUserCornSeedStock" text="0 Graine de Maïs" />
                        <Label fx:id="lblUserCarrotSeedStock" text="0 Graine de Carotte" />
                        <Label fx:id="lblUserPotatoSeedStock" text="0 Graine de Pomme de terre" />
                    </children>
                </VBox>

                <VBox prefWidth="380.0" spacing="5.0" style="-fx-background-color: #d7ccc8; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #a1887f;">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #5d4037;" text="STOCK RÉCOLTES" />
                        <Label fx:id="lblUserWheatStock" text="0 Blé" />
                        <Label fx:id="lblUserCornStock" text="0 Maïs" />
                        <Label fx:id="lblUserCarrotStock" text="0 Carotte" />
                        <Label fx:id="lblUserPotatoStock" text="0 Pomme de terre" />
                    </children>
                </VBox>
            <VBox prefWidth="380.0" spacing="5.0" style="-fx-background-color: #d7ccc8; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #a1887f;">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #5d4037;" text="STOCK ÉLEVAGES" />
                  <Label fx:id="lblUserMilkStock" text="0 Lait" />
                  <Label fx:id="lblUserEggStock" text="0 Oeuf" />
                  <Label fx:id="lblUserLeatherStock" text="0 Cuir" />
                  <Label fx:id="lblUserWoolStock" text="0 Laine" />
               </children>
            </VBox>
            <VBox prefWidth="380.0" spacing="5.0" style="-fx-background-color: #d7ccc8; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #a1887f;">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #5d4037;" text="STOCK ANIMAUX" />
                  <Label fx:id="lblUserCowStock" text="0 Vache" />
                  <Label fx:id="lblUserChickenStock" text="0 Poule" />
                  <Label fx:id="lblUserPigStock" text="0 Cochon" />
                  <Label fx:id="lblUserSheepStock" text="0 Mouton" />
               </children>
            </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
